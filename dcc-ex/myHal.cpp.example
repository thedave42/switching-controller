// myHal.cpp — DCC-EX HAL configuration for Switching Controller
//
// Copy this file to your EX-CommandStation source folder and rename to myHal.cpp.
// This registers the Switching Controller HAL driver at startup.
//
// See: https://dcc-ex.com/reference/developers/hal-config.html#adding-a-new-device

#include "IODevice.h"
#include "IO_SwitchingController.h"

void halSetup() {
  // Switching Controller: 12 turnout VPINs starting at 800, I2C address 0x65
  // Adjust the address if you have changed SC_I2C_ADDRESS in the Switching Controller firmware.
  SwitchingController::create(800, 12, 0x65);
}
